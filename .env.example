# ─── Indian Divorce Coach — Environment Variables ─────────────────────────────
#
# USAGE:
#   1. Copy this file:       cp .env.example .env.local
#   2. Fill in real values   (never commit .env.local to git)
#   3. Add each key as a     GitHub Actions secret for CI/CD deployment
#      (Settings → Secrets and variables → Actions → New repository secret)
#
# All variables must start with VITE_ to be exposed to the browser bundle.
# Access them in code via:  import.meta.env.VITE_VARIABLE_NAME
# ─────────────────────────────────────────────────────────────────────────────


# ── Calendly ──────────────────────────────────────────────────────────────────
# Your Calendly scheduling link for the inline booking embed.
# Format:  https://calendly.com/YOUR-USERNAME/EVENT-TYPE
# Where to find it: calendly.com → Event Types → copy the event link
VITE_CALENDLY_URL=https://calendly.com/YOUR-USERNAME/discovery-call


# ── WhatsApp ──────────────────────────────────────────────────────────────────
# Your WhatsApp business number in international format (digits only, no +).
# Example: India +91 98765 43210  → 919876543210
#          UK    +44 7911 123456  → 447911123456
VITE_WHATSAPP_NUMBER=919999999999


# ── Contact Email ─────────────────────────────────────────────────────────────
# The public-facing contact email displayed in the footer and booking section.
VITE_EMAIL=hello@indiandivorcecoach.com


# ── Google Analytics ──────────────────────────────────────────────────────────
# Your GA4 Measurement ID.
# Where to find it: Google Analytics → Admin → Data Streams → your stream
# Format: G-XXXXXXXXXX
# Leave blank (or remove) to disable Analytics tracking entirely.
VITE_GA_TRACKING_ID=G-XXXXXXXXXX
